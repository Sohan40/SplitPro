rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function clientWritableUserFields() {
      return [
        'id',
        'name',
        'email',
        'photoUrl',
        'createdAt',
        'updatedAt',
        'fcmTokens'
      ];
    }

    function userCreateFieldsAreSafe() {
      return request.resource.data.keys().hasOnly(clientWritableUserFields());
    }

    function userUpdateFieldsAreSafe() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'photoUrl', 'updatedAt', 'fcmTokens']);
    }

    function isFirestoreDate(value) {
      return value is number || value is timestamp;
    }

    function validUserProfile(uid) {
      return request.resource.data.id == uid
        && request.resource.data.name is string
        && request.resource.data.email is string
        && isFirestoreDate(request.resource.data.createdAt)
        && (!('photoUrl' in request.resource.data)
          || request.resource.data.photoUrl == null
          || request.resource.data.photoUrl is string)
        && (!('updatedAt' in request.resource.data)
          || isFirestoreDate(request.resource.data.updatedAt))
        && (!('fcmTokens' in request.resource.data)
          || request.resource.data.fcmTokens is list);
    }

    function groupFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'id',
        'name',
        'createdBy',
        'members',
        'memberIds',
        'balances',
        'currency',
        'createdAt',
        'updatedAt'
      ]);
    }

    function validCurrency(value) {
      return value in ['INR', 'USD', 'EUR', 'GBP', 'AED'];
    }

    function groupCurrencyUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['currency']);
    }

    function validGroup(groupId) {
      return groupFieldsAreSafe()
        && request.resource.data.id == groupId
        && request.resource.data.name is string
        && request.resource.data.createdBy is string
        && request.resource.data.members is list
        && request.resource.data.memberIds is list
        && request.resource.data.balances is map
        && (!('currency' in request.resource.data)
          || validCurrency(request.resource.data.currency))
        && request.resource.data.createdAt is number
        && request.resource.data.updatedAt is number;
    }

    function isMemberOfGroupData(groupData) {
      return isSignedIn()
        && request.auth.uid in groupData.memberIds;
    }

    function isGroupMember(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId))
        && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId))
          .data.memberIds;
    }

    function isGroupMemberUid(groupId, uid) {
      return exists(/databases/$(database)/documents/groups/$(groupId))
        && uid in get(/databases/$(database)/documents/groups/$(groupId))
          .data.memberIds;
    }

    function expenseFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'id',
        'groupId',
        'description',
        'amount',
        'category',
        'paidBy',
        'splitType',
        'participants',
        'createdBy',
        'createdAt',
        'updatedBy',
        'updatedAt'
      ]);
    }

    function validExpense() {
      return expenseFieldsAreSafe()
        && request.resource.data.groupId is string
        && request.resource.data.description is string
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.category in [
          'rent',
          'groceries',
          'utilities',
          'food',
          'transport',
          'entertainment',
          'shopping',
          'health',
          'travel',
          'education',
          'subscriptions',
          'gifts',
          'pets',
          'fitness',
          'sports',
          'others',
          'payment'
        ]
        && request.resource.data.paidBy is map
        && request.resource.data.paidBy.uid is string
        && request.resource.data.paidBy.name is string
        && request.resource.data.splitType in [
          'equal',
          'custom',
          'percentage',
          'shares',
          'payment'
        ]
        && request.resource.data.participants is list
        && request.resource.data.createdBy is string
        && request.resource.data.createdAt is number
        && (!('updatedBy' in request.resource.data)
          || request.resource.data.updatedBy is string)
        && (!('updatedAt' in request.resource.data)
          || request.resource.data.updatedAt is number)
        && isGroupMember(request.resource.data.groupId)
        && isGroupMemberUid(
          request.resource.data.groupId,
          request.resource.data.paidBy.uid
        );
    }

    function expenseImmutableFieldsUnchanged(expenseId) {
      return request.resource.data.id == resource.data.id
        && request.resource.data.id == expenseId
        && request.resource.data.groupId == resource.data.groupId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validExpenseUpdater() {
      return ('updatedBy' in request.resource.data)
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function notificationFieldsAreSafe() {
      return request.resource.data.keys().hasOnly([
        'id',
        'userId',
        'title',
        'body',
        'type',
        'read',
        'createdAt',
        'data'
      ]);
    }

    function validNotificationData() {
      return request.resource.data.data is map
        && request.resource.data.data.keys().hasOnly(['groupId', 'expenseId'])
        && request.resource.data.data.groupId is string
        && request.resource.data.data.groupId.size() > 0
        && (!('expenseId' in request.resource.data.data)
          || request.resource.data.data.expenseId is string);
    }

    function validNotification(notificationId) {
      return notificationFieldsAreSafe()
        && request.resource.data.id == notificationId
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 240
        && request.resource.data.type in ['expense', 'group_add', 'general']
        && request.resource.data.read is bool
        && request.resource.data.read == false
        && request.resource.data.createdAt is number
        && validNotificationData();
    }

    function canCreateGroupNotification(notificationId) {
      return isSignedIn()
        && validNotification(notificationId)
        && isGroupMember(request.resource.data.data.groupId)
        && isGroupMemberUid(
          request.resource.data.data.groupId,
          request.resource.data.userId
        );
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid)
        && userCreateFieldsAreSafe()
        && validUserProfile(uid);
      allow update: if isSelf(uid)
        && userUpdateFieldsAreSafe()
        && validUserProfile(uid);
      allow delete: if false;
    }

    match /groups/{groupId} {
      allow read: if isMemberOfGroupData(resource.data);
      allow create: if isSignedIn()
        && validGroup(groupId)
        && ('currency' in request.resource.data)
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow update: if isMemberOfGroupData(resource.data)
        && validGroup(groupId)
        && groupCurrencyUnchanged();
      allow delete: if isMemberOfGroupData(resource.data);
    }

    match /expenses/{expenseId} {
      allow read: if isGroupMember(resource.data.groupId);
      allow create: if isSignedIn()
        && validExpense()
        && request.resource.data.id == expenseId
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isGroupMember(resource.data.groupId)
        && validExpense()
        && expenseImmutableFieldsUnchanged(expenseId)
        && validExpenseUpdater();
      allow delete: if isGroupMember(resource.data.groupId);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if canCreateGroupNotification(notificationId);
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true;
      allow delete: if false;
    }

    match /groups/{groupId}/aiInsights/{insightId} {
      allow read: if isGroupMember(groupId);
      allow write: if false;
    }

    match /groups/{groupId}/activity/{activityId} {
      allow read: if isGroupMember(groupId);
      allow write: if false;
    }

    match /subscriptions/{uid} {
      allow read, write: if false;
    }

    match /subscriptionTokens/{tokenHash} {
      allow read, write: if false;
    }

    match /subscriptionEvents/{eventId} {
      allow read, write: if false;
    }

    match /aiUsageEvents/{eventId} {
      allow read, write: if false;
    }

    match /qrInvites/{tokenId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
